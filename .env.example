# ─────────────────────────────────────────────────────────────────────────────
# Hybrid AI Software Agency — Environment Variables
# Copy this file to .env and fill in your values.  DO NOT commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloud Agents (Project Architect + Code Reviewer + Team Leader) ────────────
# API key shared by all 3 cloud agents regardless of provider.
# Leave blank when using OpenRouter-only cloud execution.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=your_openai_api_base_url_here

# Base OpenAI model — used by all 3 cloud agents unless a per-agent override is set.
OPENAI_MODEL_NAME=gpt-4o

# Per-agent overrides (remove the leading # to activate).
# Useful when you want a cheaper model for one role and a stronger one for another.
# CLOUD_MODEL_ARCHITECT=gpt-4o          # Project Architect  — system design & scaffold
# CLOUD_MODEL_REVIEWER=gpt-4o           # Code Reviewer      — OWASP analysis & review gate
# CLOUD_MODEL_LEADER=gpt-4o             # Team Leader        — VERDICT quality gates

# ── Local Workers (Ollama — AMD Ryzen AI Max+) ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_MODEL_BACKEND=llama3             # Backend Developer
OLLAMA_MODEL_FRONTEND=llama3            # Frontend Developer
OLLAMA_MODEL_TESTER=mistral             # QA / Test Engineer
OLLAMA_MODEL_REVIEWER=mistral           # Technical Writer
OLLAMA_MODEL_DEVOPS=llama3              # DevOps Agent

# ── Optional: OpenRouter (overrides OpenAI + Ollama when enabled) ─────────────
# OpenRouter, tek bir API anahtarıyla 200+ modele erişim sağlar.
# https://openrouter.ai/keys
#
OPENROUTER_API_KEY=your_openrouter_api_key_here
#
# Cloud Orchestrator'ı OpenRouter üzerinden çalıştır (USE_OPENROUTER_CLOUD=true)
# Not: OPENAI_API_KEY boşsa OpenRouter anahtarı otomatik olarak OpenAI uyumlu
# embeddingler için de kullanılacaktır.
USE_OPENROUTER_CLOUD=false

# Base OpenRouter cloud model — used by all 3 cloud agents unless overridden below.
OPENROUTER_CLOUD_MODEL=openai/gpt-4o-mini

# Per-agent overrides (remove the leading # to activate).
# OPENROUTER_CLOUD_MODEL_ARCHITECT=openai/gpt-4.1              # Project Architect
# OPENROUTER_CLOUD_MODEL_REVIEWER=anthropic/claude-sonnet-4    # Code Reviewer
# OPENROUTER_CLOUD_MODEL_LEADER=openai/gpt-4.1                 # Team Leader
#
# Eğer OpenRouter model adı "nvidia/..." veya "poolside/..." gibi
# provider-prefiksi içermiyorsa, sistem otomatik olarak "openrouter/" ekler.
# OPENROUTER_CLOUD_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free
#
# Worker ajanları OpenRouter üzerinden çalıştır (USE_OPENROUTER_LOCAL=true)
# Not: OLLAMA_BASE_URL belirtilmişse Ollama öncelikli kullanılır, ancak OpenRouter
# anahtarı verildi ve bu bayrak true ise OpenRouter kullanılacaktır.
USE_OPENROUTER_LOCAL=false

# Base OpenRouter local model — used by all worker agents unless overridden below.
OPENROUTER_LOCAL_MODEL=openai/gpt-4o-mini

# Per-agent overrides (remove the leading # to activate).
# OPENROUTER_LOCAL_MODEL_BACKEND=openai/gpt-4o-mini     # Backend Developer
# OPENROUTER_LOCAL_MODEL_FRONTEND=openai/gpt-4o-mini    # Frontend Developer
# OPENROUTER_LOCAL_MODEL_TESTER=openai/gpt-4o-mini      # QA / Test Engineer
# OPENROUTER_LOCAL_MODEL_REVIEWER=openai/gpt-4o-mini    # Technical Writer
# OPENROUTER_LOCAL_MODEL_DEVOPS=openai/gpt-4o-mini      # DevOps Agent

# ── Optional: Deepseek (OpenAI-uyumlu, https://platform.deepseek.com) ────────
# Deepseek, OpenAI API'siyle tam uyumludur; kendi API anahtarıyla bağımsız
# olarak yapılandırılabilir.  OPENAI_API_KEY'den etkilenmez.
# https://platform.deepseek.com/api_keys
#
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
#
# Cloud Orchestrator'ı (Architect / Reviewer / Leader) Deepseek üzerinden çalıştır
USE_DEEPSEEK_CLOUD=false

# Base Deepseek cloud model — tüm cloud ajanlar için varsayılan.
DEEPSEEK_CLOUD_MODEL=deepseek-chat

# Per-agent overrides (leading # kaldırarak aktive et).
# DEEPSEEK_CLOUD_MODEL_ARCHITECT=deepseek-chat        # Project Architect
# DEEPSEEK_CLOUD_MODEL_REVIEWER=deepseek-chat         # Code Reviewer
# DEEPSEEK_CLOUD_MODEL_LEADER=deepseek-chat           # Team Leader
#
# Worker ajanları Deepseek üzerinden çalıştır (USE_DEEPSEEK_LOCAL=true)
# Not: OLLAMA_BASE_URL tanımlıysa Ollama öncelikli; bu bayrak true ise Deepseek kullanılır.
USE_DEEPSEEK_LOCAL=false

# Base Deepseek local model — tüm worker ajanlar için varsayılan.
DEEPSEEK_LOCAL_MODEL=deepseek-chat

# Per-agent overrides (leading # kaldırarak aktive et).
# DEEPSEEK_LOCAL_MODEL_BACKEND=deepseek-chat          # Backend Developer
# DEEPSEEK_LOCAL_MODEL_FRONTEND=deepseek-chat         # Frontend Developer
# DEEPSEEK_LOCAL_MODEL_TESTER=deepseek-chat           # QA / Test Engineer
# DEEPSEEK_LOCAL_MODEL_REVIEWER=deepseek-chat         # Technical Writer
# DEEPSEEK_LOCAL_MODEL_DEVOPS=deepseek-chat           # DevOps Agent
#
# Kullanılabilir modeller:
#   deepseek-chat      — genel amaçlı, çok yönlü (önerilen)
#   deepseek-reasoner  — uzun zincir akıl yürütme gerektiren görevler için (R1)
#   deepseek-coder     — kod odaklı görevler için (eski sürüm)

# ── Optional — override the default feature request ──────────────────────────
# Seçenek 1: Dosya yolu ver — içeriği otomatik okunur (Markdown/TXT destekli)
# FEATURE_REQUEST_FILE=HYBRID_AI_AGENCY_README.md
#
# Seçenek 2: Kısa bir istek satırı yaz
# FEATURE_REQUEST=Build a TODO REST API with a React frontend
